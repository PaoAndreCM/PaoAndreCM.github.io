---
interface Props {
  title: string;
  summary: string;
  context?: string;
  cover?: string;
  tech: string[];
  hard_skills: string[];
  soft_skills: string[];
  slug: string;
}

const { title, summary, context, cover, tech, hard_skills, soft_skills, slug } = Astro.props;
---

<article class="relative grid grid-cols-1 md:grid-cols-3 border border-gray-200 rounded-lg overflow-hidden min-h-64 hover:border-gray-400 transition-colors">
  <a href={`/projects/${slug}`} class="absolute inset-0 z-0" aria-label={`Learn more about ${title}`}></a>

  <!-- Left: cover image (hidden on mobile) -->
  <div class="hidden md:flex col-span-1 bg-gray-100 items-center justify-center overflow-hidden">
    {cover
      ? <img src={cover} alt={title} class="w-full h-full object-cover" />
      : <span class="text-gray-300 text-sm">No image</span>
    }
  </div>

  <!-- Middle: title + summary + learn more -->
  <div class="col-span-1 p-6 flex flex-col justify-center border-x border-gray-200">
    {context && <p class="text-xs text-gray-400 uppercase tracking-wide mb-2">{context}</p>}
    <h3 class="text-lg font-semibold mb-3">{title}</h3>
    <p class="text-sm text-gray-600 leading-relaxed mb-4">{summary}</p>
    <a
      href={`/projects/${slug}`}
      class="relative z-10 text-sm font-medium text-gray-900 hover:underline underline-offset-4 self-start"
    >
      Learn more →
    </a>
  </div>

  <!-- Right: 3 rows (hidden on mobile) -->
  <div class="hidden md:flex col-span-1 flex-col divide-y divide-gray-200">

    <!-- Tech stack -->
    <div class="p-4 flex flex-col gap-2 flex-1">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Tech</p>
      <div class="flex flex-wrap gap-1">
        {tech.map(tag => (
          <span class="bg-gray-100 text-gray-700 text-xs px-2 py-0.5 rounded-full">{tag}</span>
        ))}
      </div>
    </div>

    <!-- Hard skills -->
    <div class="p-4 flex flex-col gap-2 flex-1">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Hard skills</p>
      <div class="flex flex-wrap gap-1">
        {hard_skills.map(tag => (
          <span class="bg-blue-50 text-blue-700 text-xs px-2 py-0.5 rounded-full">{tag}</span>
        ))}
      </div>
    </div>

    <!-- Soft skills -->
    <div class="p-4 flex flex-col gap-2 flex-1">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide">Soft skills</p>
      <div class="flex flex-wrap gap-1">
        {soft_skills.map(tag => (
          <span class="bg-emerald-50 text-emerald-700 text-xs px-2 py-0.5 rounded-full">{tag}</span>
        ))}
      </div>
    </div>

  </div>
</article>
